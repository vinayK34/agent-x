# ===== AgentX — local config =====
# Copy to .env and fill in values you have. Defaults are designed to "just work".

# --- LLM provider (OpenAI-compatible). Leave empty to use the deterministic stub.
OPENAI_API_KEY=
# Point at Ollama, Groq, or any OpenAI-compatible gateway if desired,
# e.g. http://host.docker.internal:11434/v1
OPENAI_BASE_URL=
DEFAULT_MODEL=gpt-4o-mini
# Set true for endpoints without OpenAI tool-calling support (e.g. plain vLLM).
DISABLE_TOOL_CALLING=false

# --- Telegram (get a token from @BotFather). Leave empty to disable telegram.
TELEGRAM_BOT_TOKEN=

# --- Persistence
DATABASE_URL=sqlite+aiosqlite:///./data/agentx.db

# --- App
APP_ENV=dev
CORS_ORIGINS=["http://localhost:3000"]
ENABLED_CHANNELS=["telegram"]
DEFAULT_MAX_STEPS=20
DEFAULT_MAX_COST_USD=1.0

# --- Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
